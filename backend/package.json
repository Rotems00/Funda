{
  "name": "funda-backend",
  "version": "0.1.0",
  "description": "Funda stock rating backend - Node.js + Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node scripts/seed.ts",
    "test": "jest",
    "test:rating": "ts-node scripts/testRating.ts",
    "debug:stock": "ts-node scripts/debugStock.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "stock",
    "fundamentals",
    "rating",
    "polygon"
  ],
  "author": "Funda Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^18.15.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1"
  }
}
